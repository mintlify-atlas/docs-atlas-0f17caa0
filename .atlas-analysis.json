    "dbr --check-inventory USER_ID",
    "dbr --download-mgs-invalid-list",
    "dbr --download-badge-spam-lists",
    "dbr --mgs-id MGS_ID",
    "dbr --use-bor-badge-database",
    "dbr --env-file ENV_FILE",
    "dbr --rbx-token RBX_TOKEN",
    "dbr --delete-threads NUM_THREADS",
